      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">35</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [xkp, yk] = RNN(xk, uk, yk_meas, t)

    if t &lt;= 1
        xk = 0*ones(18, 1);
    end

    n_states = [3,3,3,3,3,3];
    layers_file = load(&quot;layers_file.mat&quot;);
    layers_file = layers_file.layers_file;
    input_scaler_bias = load(&quot;input_scaler_bias.mat&quot;);
    input_scaler_scale_common = load(&quot;input_scaler_scale_common.mat&quot;);
    output_scaler_bias = load(&quot;output_scaler_bias.mat&quot;);
    output_scaler_scale_common = load(&quot;output_scaler_scale_common.mat&quot;);
    
    % Best observer weight
    Lz1_sol = load(&quot;Lz1_sol.mat&quot;);
    Lf1_sol = load(&quot;Lf1_sol.mat&quot;);
    Lz1 = Lz1_sol.Lz1;
    Lf1 = Lf1_sol.Lf1;
    Lz2_sol = load(&quot;Lz2_sol.mat&quot;);
    Lf2_sol = load(&quot;Lf2_sol.mat&quot;);
    Lz2 = Lz2_sol.Lz2;
    Lf2 = Lf2_sol.Lf2;
    Lz3_sol = load(&quot;Lz3_sol.mat&quot;);
    Lf3_sol = load(&quot;Lf3_sol.mat&quot;);
    Lz3 = Lz3_sol.Lz3;
    Lf3 = Lf3_sol.Lf3;
    Lz4_sol = load(&quot;Lz4_sol.mat&quot;);
    Lf4_sol = load(&quot;Lf4_sol.mat&quot;);
    Lz4 = Lz4_sol.Lz4;
    Lf4 = Lf4_sol.Lf4;
    Lz5_sol = load(&quot;Lz5_sol.mat&quot;);
    Lf5_sol = load(&quot;Lf5_sol.mat&quot;);
    Lz5 = Lz5_sol.Lz5;
    Lf5 = Lf5_sol.Lf5;
    Lz6_sol = load(&quot;Lz6_sol.mat&quot;);
    Lf6_sol = load(&quot;Lf6_sol.mat&quot;);
    Lz6 = Lz6_sol.Lz6;
    Lf6 = Lf6_sol.Lf6;

    % Scale input and output
    uk = (uk  - (input_scaler_bias.input_scaler_bias).&apos;) ./ (input_scaler_scale_common.input_scaler_scale_common).&apos;;
    %yk_meas = [yk_meas(1)*yk_meas(2); yk_meas(1)*yk_meas(3); yk_meas(1)*yk_meas(4); yk_meas(1)*yk_meas(5); yk_meas(6)*yk_meas(7); yk_meas(6)*yk_meas(8); yk_meas(6)*yk_meas(9); yk_meas(6)*yk_meas(10); yk_meas(11)*yk_meas(12); yk_meas(11)*yk_meas(13); yk_meas(11)*yk_meas(14); yk_meas(11)*yk_meas(15); yk_meas(16)*yk_meas(17); yk_meas(11)*yk_meas(18); yk_meas(11)*yk_meas(19); yk_meas(11)*yk_meas(20); yk_meas(21)*yk_meas(22); yk_meas(21)*yk_meas(23); yk_meas(21)*yk_meas(24); yk_meas(21)*yk_meas(25); yk_meas(26)*yk_meas(27); yk_meas(26)*yk_meas(28); yk_meas(26)*yk_meas(29); yk_meas(26)*yk_meas(30); yk_meas(31)*yk_meas(32); yk_meas(31)*yk_meas(33); yk_meas(31)*yk_meas(34); yk_meas(31)*yk_meas(35)];
    yk_meas = (yk_meas  - (output_scaler_bias.output_scaler_bias).&apos;) ./ (output_scaler_scale_common.output_scaler_scale_common).&apos;;

    % GRU 1
    yk1_meas = yk_meas(1:4,:);
    yk2_to1_meas = yk_meas(5:8,:);
    yk6_meas = yk_meas(25:28,:);
    uk1 = [uk(1,:); uk(3:4,:); yk2_to1_meas; yk6_meas];
    xk1 = xk(1:n_states(1),:);    
    yk1 = layers_file.layers{1,2}.weights.weight * xk1 + (layers_file.layers{1,2}.weights.bias).&apos;;
    zk1 = sigmoidfunction((layers_file.layers{1,1}.weights.Wzf(:,1:n_states(1))).&apos; * uk1 + (layers_file.layers{1,1}.weights.Uzf(:,1:n_states(1))).&apos; * xk1 + (layers_file.layers{1,1}.weights.bzf(:,1:n_states(1))).&apos; + Lz1*(yk1_meas-yk1) );
    fk1 = sigmoidfunction((layers_file.layers{1,1}.weights.Wzf(:,n_states(1)+1:end)).&apos; * uk1 + (layers_file.layers{1,1}.weights.Uzf(:,n_states(1)+1:end)).&apos; * xk1 + (layers_file.layers{1,1}.weights.bzf(:,n_states(1)+1:end)).&apos; + Lf1*(yk1_meas-yk1) );
    phi1 = tanh((layers_file.layers{1,1}.weights.Wr).&apos; * uk1 + (layers_file.layers{1,1}.weights.Ur).&apos; * (fk1.* xk1) + (layers_file.layers{1,1}.weights.br).&apos;);
    xkp1 = zk1 .* xk1 + (1-zk1) .* phi1;
    
    % GRU 2    
    yk2_meas = yk_meas(5:12,:);
    yk2_to3_meas = yk_meas(9:12,:);
    uk2 = [uk(1,:); uk(3:4,:); yk1_meas];
    xk2 = xk(n_states(1)+1:n_states(1)+n_states(2),:);
    yk2 = layers_file.layers{1,4}.weights.weight * xk2 + (layers_file.layers{1,4}.weights.bias).&apos;;
    zk2 = sigmoidfunction((layers_file.layers{1,3}.weights.Wzf(:,1:n_states(2))).&apos; * uk2 + (layers_file.layers{1,3}.weights.Uzf(:,1:n_states(2))).&apos; * xk2 + (layers_file.layers{1,3}.weights.bzf(:,1:n_states(2))).&apos; + Lz2*(yk2_meas-yk2) );
    fk2 = sigmoidfunction((layers_file.layers{1,3}.weights.Wzf(:,n_states(2)+1:end)).&apos; * uk2 + (layers_file.layers{1,3}.weights.Uzf(:,n_states(2)+1:end)).&apos; * xk2 + (layers_file.layers{1,3}.weights.bzf(:,n_states(2)+1:end)).&apos; + Lf2*(yk2_meas-yk2) );
    phi2 = tanh((layers_file.layers{1,3}.weights.Wr).&apos; * uk2 + (layers_file.layers{1,3}.weights.Ur).&apos; * (fk2.* xk2) + (layers_file.layers{1,3}.weights.br).&apos;);
    xkp2 = zk2 .* xk2 + (1-zk2) .* phi2;
    
    % GRU 3
    yk3_meas = yk_meas(13:16,:);
    uk3 = [uk(2:4,:); yk2_to3_meas];
    xk3 = xk(n_states(1)+n_states(2)+1:n_states(1)+n_states(2)+n_states(3),:);
    yk3 = layers_file.layers{1,6}.weights.weight * xk3 + (layers_file.layers{1,6}.weights.bias).&apos;;
    zk3 = sigmoidfunction((layers_file.layers{1,5}.weights.Wzf(:,1:n_states(3))).&apos; * uk3 + (layers_file.layers{1,5}.weights.Uzf(:,1:n_states(3))).&apos; * xk3 + (layers_file.layers{1,5}.weights.bzf(:,1:n_states(3))).&apos; + Lz3*(yk3_meas-yk3) );
    fk3 = sigmoidfunction((layers_file.layers{1,5}.weights.Wzf(:,n_states(3)+1:end)).&apos; * uk3 + (layers_file.layers{1,5}.weights.Uzf(:,n_states(3)+1:end)).&apos; * xk3 + (layers_file.layers{1,5}.weights.bzf(:,n_states(3)+1:end)).&apos; + Lf3*(yk3_meas-yk3) );
    phi3 = tanh((layers_file.layers{1,5}.weights.Wr).&apos; * uk3 + (layers_file.layers{1,5}.weights.Ur).&apos; * (fk3.* xk3) + (layers_file.layers{1,5}.weights.br).&apos;);
    xkp3 = zk3 .* xk3 + (1-zk3) .* phi3;

    % GRU 4
    yk4_meas = yk_meas(17:20,:);
    uk4 = [uk(2:4,:); yk3_meas];
    xk4 = xk(n_states(1)+n_states(2)+n_states(3)+1:n_states(1)+n_states(2)+n_states(3)+n_states(4),:);
    yk4 = layers_file.layers{1,8}.weights.weight * xk4 + (layers_file.layers{1,8}.weights.bias).&apos;;
    zk4 = sigmoidfunction((layers_file.layers{1,7}.weights.Wzf(:,1:n_states(4))).&apos; * uk4 + (layers_file.layers{1,7}.weights.Uzf(:,1:n_states(4))).&apos; * xk4 + (layers_file.layers{1,7}.weights.bzf(:,1:n_states(4))).&apos; + Lz4*(yk4_meas-yk4) );
    fk4 = sigmoidfunction((layers_file.layers{1,7}.weights.Wzf(:,n_states(4)+1:end)).&apos; * uk4 + (layers_file.layers{1,7}.weights.Uzf(:,n_states(4)+1:end)).&apos; * xk4 + (layers_file.layers{1,7}.weights.bzf(:,n_states(4)+1:end)).&apos; + Lf4*(yk4_meas-yk4) );
    phi4 = tanh((layers_file.layers{1,7}.weights.Wr).&apos; * uk4 + (layers_file.layers{1,7}.weights.Ur).&apos; * (fk4.* xk4) + (layers_file.layers{1,7}.weights.br).&apos;);
    xkp4 = zk4 .* xk4 + (1-zk4) .* phi4;

    % GRU 5
    yk5_meas = yk_meas(21:24,:);
    uk5 = [uk(2:4,:); yk4_meas];
    xk5 = xk(n_states(1)+n_states(2)+n_states(3)+n_states(4)+1:n_states(1)+n_states(2)+n_states(3)+n_states(4)+n_states(5),:);
    yk5 = layers_file.layers{1,10}.weights.weight * xk5 + (layers_file.layers{1,10}.weights.bias).&apos;;
    zk5 = sigmoidfunction((layers_file.layers{1,9}.weights.Wzf(:,1:n_states(5))).&apos; * uk5 + (layers_file.layers{1,9}.weights.Uzf(:,1:n_states(5))).&apos; * xk5 + (layers_file.layers{1,9}.weights.bzf(:,1:n_states(5))).&apos; + Lz5*(yk5_meas-yk5) );
    fk5 = sigmoidfunction((layers_file.layers{1,9}.weights.Wzf(:,n_states(5)+1:end)).&apos; * uk5 + (layers_file.layers{1,9}.weights.Uzf(:,n_states(5)+1:end)).&apos; * xk5 + (layers_file.layers{1,9}.weights.bzf(:,n_states(5)+1:end)).&apos; + Lf5*(yk5_meas-yk5) );
    phi5 = tanh((layers_file.layers{1,9}.weights.Wr).&apos; * uk5 + (layers_file.layers{1,9}.weights.Ur).&apos; * (fk5.* xk5) + (layers_file.layers{1,9}.weights.br).&apos;);
    xkp5 = zk5 .* xk5 + (1-zk5) .* phi5;

    % GRU 6
    uk6 = [uk(2:4,:); yk5_meas];
    xk6 = xk(n_states(1)+n_states(2)+n_states(3)+n_states(4)+n_states(5)+1:n_states(1)+n_states(2)+n_states(3)+n_states(4)+n_states(5)+n_states(6),:);
    yk6 = layers_file.layers{1,12}.weights.weight * xk6 + (layers_file.layers{1,12}.weights.bias).&apos;;
    zk6 = sigmoidfunction((layers_file.layers{1,11}.weights.Wzf(:,1:n_states(6))).&apos; * uk6 + (layers_file.layers{1,11}.weights.Uzf(:,1:n_states(6))).&apos; * xk6 + (layers_file.layers{1,11}.weights.bzf(:,1:n_states(6))).&apos; + Lz6*(yk6_meas-yk6) );
    fk6 = sigmoidfunction((layers_file.layers{1,11}.weights.Wzf(:,n_states(6)+1:end)).&apos; * uk6 + (layers_file.layers{1,11}.weights.Uzf(:,n_states(6)+1:end)).&apos; * xk6 + (layers_file.layers{1,11}.weights.bzf(:,n_states(6)+1:end)).&apos; + Lf6*(yk6_meas-yk6) );
    phi6 = tanh((layers_file.layers{1,11}.weights.Wr).&apos; * uk6 + (layers_file.layers{1,11}.weights.Ur).&apos; * (fk6.* xk6) + (layers_file.layers{1,11}.weights.br).&apos;);
    xkp6 = zk6 .* xk6 + (1-zk6) .* phi6;
    
    % Overall
    xkp = [xkp1; xkp2; xkp3; xkp4; xkp5; xkp6];
    yk = [yk1; yk2; yk3; yk4; yk5; yk6];
    yk = yk .* (output_scaler_scale_common.output_scaler_scale_common).&apos; + (output_scaler_bias.output_scaler_bias).&apos;;
end</P>
      </eml>
    </state>
    <data SSID="25" name="xkp">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="4" name="xk">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="6" name="uk">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="27" name="yk_meas">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="28" name="t">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="24" name="yk">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <transition SSID="2">
      <P Name="labelString">{eML_blk_kernel();}</P>
      <P Name="labelPosition">[28.125 13.875 102.544 14.964]</P>
      <P Name="fontSize">12</P>
      <src>
        <P Name="intersection">[0 0 1 0 23.5747 14.625 0 0]</P>
      </src>
      <dst>
        <P Name="SSID">3</P>
        <P Name="intersection">[1 0 -1 0 23.5747 42.5747 0 0]</P>
      </dst>
      <P Name="midPoint">[23.5747 24.9468]</P>
      <P Name="dataLimits">[21.175 25.975 14.625 42.575]</P>
      <P Name="subviewer">35</P>
      <P Name="drawStyle">SMART</P>
      <slide>
        <P Name="sticky">BOTH_STICK</P>
      </slide>
      <P Name="executionOrder">1</P>
    </transition>
    <junction SSID="3">
      <P Name="position">[23.5747 49.5747 7]</P>
      <P Name="subviewer">35</P>
